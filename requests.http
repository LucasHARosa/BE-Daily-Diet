# ─────────────────────────────────────────
# HEALTH
# ─────────────────────────────────────────

### Health check
GET {{baseUrl}}/health

# ─────────────────────────────────────────
# AUTH
# ─────────────────────────────────────────

### Criar usuário
POST {{baseUrl}}/users
Content-Type: application/json

{
  "name": "Lucas",
  "email": "lucas@email.com",
  "password": "12345678"
}

###

### Login
POST {{baseUrl}}/sessions
Content-Type: application/json

{
  "email": "lucas@email.com",
  "password": "12345678"
}

###

### Renovar token (refresh)
POST {{baseUrl}}/sessions/refresh
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}

###

### Me (rota protegida — precisa do token)
GET {{baseUrl}}/me
Authorization: Bearer {{token}}

# ─────────────────────────────────────────
# REFEIÇÕES (Fase 3 — ainda não implementado)
# ─────────────────────────────────────────

### Criar refeição
# POST {{baseUrl}}/meals
# Authorization: Bearer {{token}}
# Content-Type: application/json
#
# {
#   "name": "Almoço",
#   "description": "Arroz, feijão e frango",
#   "eaten_at": "2026-06-15T12:00:00Z",
#   "is_on_diet": true,
#   "calories": 650
# }

### Listar refeições
# GET {{baseUrl}}/meals
# Authorization: Bearer {{token}}

### Listar refeições com filtros
# GET {{baseUrl}}/meals?start=2026-06-01&end=2026-06-30&status=on_diet
# Authorization: Bearer {{token}}

### Buscar refeição por ID
# GET {{baseUrl}}/meals/ID_AQUI
# Authorization: Bearer {{token}}

### Editar refeição
# PUT {{baseUrl}}/meals/ID_AQUI
# Authorization: Bearer {{token}}
# Content-Type: application/json
#
# {
#   "name": "Almoço editado",
#   "description": "Arroz, feijão, frango e salada",
#   "eaten_at": "2026-06-15T12:30:00Z",
#   "is_on_diet": true,
#   "calories": 700
# }

### Excluir refeição
# DELETE {{baseUrl}}/meals/ID_AQUI
# Authorization: Bearer {{token}}

# ─────────────────────────────────────────
# MÉTRICAS (Fase 4 — ainda não implementado)
# ─────────────────────────────────────────

### Resumo geral
# GET {{baseUrl}}/metrics/summary
# Authorization: Bearer {{token}}

### Métricas por período agrupadas por dia
# GET {{baseUrl}}/metrics?start=2026-06-01&end=2026-06-30&groupBy=day
# Authorization: Bearer {{token}}

### Métricas por período agrupadas por mês
# GET {{baseUrl}}/metrics?start=2026-01-01&end=2026-12-31&groupBy=month
# Authorization: Bearer {{token}}

