### Criar plano alimentar
# POST {{baseUrl}}/food-plans
# Authorization: Bearer {{token}}
# Content-Type: application/json
#
# {
#   "title": "Plano Semana 1",
#   "description": "Plano de dieta para a primeira semana"
# }

### Listar planos
# GET {{baseUrl}}/food-plans
# Authorization: Bearer {{token}}

### Plano ativo
# GET {{baseUrl}}/food-plans/active
# Authorization: Bearer {{token}}

# ─────────────────────────────────────────
# PERFIL (Fase 6 — ainda não implementado)
# ─────────────────────────────────────────

### Buscar perfil
# GET {{baseUrl}}/me/profile
# Authorization: Bearer {{token}}

### Atualizar perfil
# PATCH {{baseUrl}}/me/profile
# Authorization: Bearer {{token}}
# Content-Type: application/json
#
# {
#   "weight_kg": 80.5,
#   "height_cm": 178,
#   "activity_level": "moderate",
#   "gym_frequency_per_week": 4
# }

